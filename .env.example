# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# WooCommerce
WOO_URL=https://yourstore.com
WOO_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret set on the WooCommerce webhook (used to verify x-wc-webhook-signature).
# Leave empty to skip signature verification (not recommended in production).
WOO_WEBHOOK_SECRET=

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id
# Paste the full service-account JSON on one line, OR a base64-encoded version of it,
# OR an absolute path to the JSON key file.
GOOGLE_SERVICE_ACCOUNT_JSON=

# WhatsApp (group id looks like 123456789012345678@g.us)
WHATSAPP_GROUP_ID=

# Which order statuses trigger the notification (comma-separated).
# Default "processing" = confirmed orders only (COD placed / payment completed).
NOTIFY_ORDER_STATUSES=processing
