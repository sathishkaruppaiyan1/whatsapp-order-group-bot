{
  "name": "woocommerce-order-automation-bot",
  "version": "1.0.0",
  "description": "Background automation service: WooCommerce orders -> WhatsApp group + Google Sheets",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test:image": "tsx scripts/test-image.ts",
    "test:http": "tsx scripts/smoke-test.ts",
    "whatsapp:groups": "tsx scripts/list-groups.ts",
    "check:google": "tsx scripts/check-google.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "canvas": "^3.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "puppeteer": "^24.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "whatsapp-web.js": "^1.34.7",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
